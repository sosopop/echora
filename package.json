{
  "name": "echora",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Echora V1 MVP — 英语场景对话练习 AI Agent",
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "dev": "node scripts/dev-server.js",
    "dev:web": "vite",
    "build": "tsc -p tsconfig.server.json && vite build",
    "test": "npm run test:server && npm run test:web && npm run test:smoke && npm run test:smoke:onboarding && npm run test:smoke:learning",
    "test:unit": "npm run test:server && npm run test:web",
    "test:server": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand",
    "test:web": "vitest run",
    "test:smoke": "tsx tests/smoke/run-smoke.ts",
    "test:smoke:onboarding": "tsx tests/smoke/run-smoke-onboarding.ts",
    "test:smoke:learning": "tsx tests/smoke/run-smoke-learning.ts",
    "test:smoke:ai": "tsx tests/smoke/run-smoke-ai.ts",
    "migrate": "tsx server/db/migrate.ts",
    "release": "node scripts/release.js",
    "start": "node dist-server/server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.1",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.38.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.3.3",
    "jest": "^29.7.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.5",
    "zustand": "^5.0.1"
  }
}
