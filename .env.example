# —— 后端 ————————————————————————————————————————————————
SERVER_PORT=8787
# 可选 JSON 配置文件路径(优先级:env > file > 内置默认)
# SERVER_CONFIG_PATH=./echora.config.json
DATABASE_PATH=./db/echora.db
JWT_SECRET=echora-dev-secret-change-me

# —— AI Provider ——————————————————————————————————————————
# stub:零配置启动,所有路由命中 general-chat
# anthropic:接入真实 Claude API,onboarding 等 Skill 才能用 LLM 流式对话
# openai:接入 OpenAI / 兼容协议(支持 OPENAI_BASE_URL 自定义中转)
AI_PROVIDER=stub

# —— Anthropic ————————————————————————————————————————————
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# —— OpenAI ——————————————————————————————————————————————
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 注意:Provider 缺 key 或 endpoint 不可达时 **不会 fallback 到 stub**,
# createProvider 与 AIRouter 都会抛错,让问题立即暴露。生产环境想要
# 降级行为请在应用层显式实现。

CORS_ORIGIN=http://localhost:5173
NODE_ENV=development

# —— 前端(Vite 自动加载,VITE_ 前缀必须) ——————————————
VITE_API_BASE_URL=/api
